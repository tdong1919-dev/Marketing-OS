# ─────────────────────────────────────────────────────────────
# Jidoka Marketing Team OS — Environment Variables
# Copy to `.env.local` and fill in. NEVER commit `.env.local`.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. Bypasses RLS — used by API routes for privileged writes.
# Project Settings → API → service_role secret. DO NOT expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# Login mode. Default is normal Supabase login. Set JIDOKA_LOGIN_DISABLED=1
# only for no-login demos. In demo mode, Jidoka Marketing Team OS can create/use a demo Auth user
# with the service-role key if the project is empty.
JIDOKA_LOGIN_DISABLED=0
JIDOKA_DEMO_EMAIL=
JIDOKA_DEMO_PASSWORD=
JIDOKA_DEMO_OWNER_ID=

# ── AI providers ──
# Claude powers Voice DNA analysis + content generation + QC scoring.
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI powers embeddings only (text-embedding-3-small, 1536 dims).
OPENAI_API_KEY=sk-...

# ── Optional model overrides ──
# Defaults are set in lib/ai/anthropic.ts and lib/ai/embeddings.ts
# ANTHROPIC_MODEL=claude-opus-4-8
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Site URL ──
# Optional stable base URL for OAuth callbacks.
JIDOKA_SITE_URL=https://marketing.jidokagroup.com
# Public legal pages for X / connected app review:
# Terms:  ${JIDOKA_SITE_URL}/terms
# Privacy: ${JIDOKA_SITE_URL}/privacy

# ─────────────────────────────────────────────────────────────
# Social integration (Smart Scheduler publishing + Analytics)
# All optional — the scheduler works for planning without them.
# ─────────────────────────────────────────────────────────────

# Absolute base URL of the deployment (OAuth redirects, media URLs).
# e.g. https://marketing.jidokagroup.com
NEXT_PUBLIC_SITE_URL=https://marketing.jidokagroup.com

# ── Billing (planned) ──
# Leave blank until the Stripe account/products are ready. The app currently
# sends new accounts directly to /dashboard and shows billing status in Settings.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_MARKETING_OS_PRICE_ID=

# Meta (Instagram / Facebook) — Jidoka Marketing Team OS can fall back to the approved Autom8 app ID.
# Permissions: instagram_basic, instagram_content_publish,
# instagram_manage_insights, instagram_manage_comments,
# instagram_manage_messages, pages_show_list, pages_read_engagement,
# pages_manage_metadata, pages_read_user_content, pages_manage_engagement.
# Production posting requires Meta App Review.
# Register OAuth redirect: ${NEXT_PUBLIC_SITE_URL}/api/social/callback
# Optional override. Leave blank to use the approved Autom8 Meta app ID.
NEXT_PUBLIC_FB_APP_ID=
# Required server-side for OAuth callback, publishing, and analytics.
FB_APP_SECRET=

# TikTok Content Posting API — possible after TikTok developer app review.
# Add once the TikTok OAuth/connect route is implemented.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# YouTube Data API / OAuth. Register redirect:
# ${NEXT_PUBLIC_SITE_URL}/api/social/youtube/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# X OAuth 2.0. Use the OAuth 2.0 Client ID/Secret from an X App that is
# attached to an X Developer Project. Old OAuth 1.0/n8n app tokens will not
# work for Jidoka Marketing Team OS's X API v2 profile lookup.
# Register redirect:
# ${JIDOKA_SITE_URL}/api/social/callback/x
# Jidoka Marketing Team OS asks for minimum read-only X scopes by default. Set X_ENABLE_REFRESH=1
# only after base login works. Set X_ENABLE_POSTING=1 only after the X app has
# Read and write permissions and media/write scopes approved.
X_CLIENT_ID=
X_CLIENT_SECRET=
# Optional. Default matches the working Autom8 OAuth start URL.
X_AUTHORIZE_URL=https://twitter.com/i/oauth2/authorize
X_ENABLE_REFRESH=0
X_ENABLE_POSTING=0
X_API_KEY=
X_API_SECRET=

# Mailchimp OAuth. Register redirect:
# ${NEXT_PUBLIC_SITE_URL}/api/social/mailchimp/callback
MAILCHIMP_CLIENT_ID=
MAILCHIMP_CLIENT_SECRET=

# Encryption key for stored OAuth tokens (AES-256-GCM).
# Generate with:  openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# Shared secret for Vercel Cron → /api/cron/* (Bearer token).
# Generate with:  openssl rand -hex 16
CRON_SECRET=
