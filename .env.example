# =============================================================
# Autom8 — Environment Variables
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.
# =============================================================

# ---------------------------------------------------------------
# Supabase
# Get these from: https://app.supabase.com → Project → Settings → API
# ---------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---------------------------------------------------------------
# Stripe
# Get these from: https://dashboard.stripe.com/apikeys
# Use test-mode keys (sk_test_...) during development.
# ---------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Stripe Price IDs — create in Stripe dashboard under Products
# Set the lookup_key on each price to match: 'starter', 'growth', 'agency'
STRIPE_STARTER_PRICE_ID=price_starter_id_here
STRIPE_GROWTH_PRICE_ID=price_growth_id_here
STRIPE_SCALE_PRICE_ID=price_scale_id_here

# ---------------------------------------------------------------
# Meta (Facebook / Instagram) OAuth
# Create an app at: https://developers.facebook.com
# Required permissions: instagram_basic, instagram_manage_comments, pages_read_engagement
# NOTE: v1 uses a placeholder flow — real credentials needed post-Meta App Review
# ---------------------------------------------------------------
META_APP_ID=your-meta-app-id-here
META_APP_SECRET=your-meta-app-secret-here

# ---------------------------------------------------------------
# App URL
# Used for OAuth redirect URIs and absolute URL construction.
# ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---------------------------------------------------------------
# (Optional) NextAuth secret — only needed if you add NextAuth.js
# Generate with: openssl rand -base64 32
# ---------------------------------------------------------------
# NEXTAUTH_SECRET=your-nextauth-secret-here
